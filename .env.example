# ─────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente do ChatCapitu
#
# Copie este arquivo para `.env` e ajuste conforme a necessidade.
# Todas as variáveis têm defaults sensatos em `config.py` — preencha aqui
# apenas o que precisar sobrescrever.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama (backend local — padrão) ──────────────────────────────────────────
# Modelo registrado no Ollama (criado a partir do Modelfile)
OLLAMA_MODEL=sabia7b
# URL do servidor Ollama
OLLAMA_BASE_URL=http://localhost:11434

# ── Maritaca API (backend cloud — opcional) ──────────────────────────────────
# Se preenchido, o ChatCapitu usa a Maritaca API em vez do Ollama local.
# Útil quando se precisa de respostas instruct-tuned (sabia-3) e não há GPU.
MARITACA_API_KEY=
MARITACA_MODEL=sabia-3

# ── Dataset ──────────────────────────────────────────────────────────────────
# Caminho para o JSON anotado do corpus.
DATASET_PATH=dom_casmurro_anotado_com_criticos.json
